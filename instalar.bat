@echo off
set SELF=%~f0
set INSTALLER_DIR=%~dp0
if "%INSTALLER_DIR:~-1%"=="\" set "INSTALLER_DIR=%INSTALLER_DIR:~0,-1%"
set TMP_PS=%TEMP%\instalar_liverpool_tmp.ps1
powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-Content '%SELF%' | Select-Object -Skip 10 | Set-Content '%TMP_PS%' -Encoding UTF8"
powershell -NoProfile -ExecutionPolicy Bypass -File "%TMP_PS%" "%INSTALLER_DIR%"
del "%TMP_PS%" 2>nul
pause
exit /b
param([string]$InstallerDir = '')

Write-Host ''
Write-Host '============================================' -ForegroundColor Cyan
Write-Host '   Liverpool Bot 456 -- Instalador          ' -ForegroundColor Cyan
Write-Host '============================================' -ForegroundColor Cyan
Write-Host ''

$PYTHONW = (Get-Command pythonw.exe -ErrorAction SilentlyContinue).Source
if (-not $PYTHONW) {
    $py = (Get-Command python.exe -ErrorAction SilentlyContinue).Source
    if ($py) { $PYTHONW = $py -replace 'python\.exe$','pythonw.exe' }
}
if (-not $PYTHONW -or -not (Test-Path $PYTHONW)) {
    Write-Host 'Python no esta en PATH, buscando...' -ForegroundColor Yellow
    $rutas = @(
        "$env:LOCALAPPDATA\Programs\Python\Python3*\pythonw.exe",
        "$env:LOCALAPPDATA\Programs\Python\Python*\pythonw.exe",
        "C:\Python3*\pythonw.exe",
        "C:\Program Files\Python3*\pythonw.exe",
        "C:\Program Files (x86)\Python3*\pythonw.exe"
    )
    foreach ($p in $rutas) {
        $found = Get-Item $p -ErrorAction SilentlyContinue | Select-Object -Last 1
        if ($found) { $PYTHONW = $found.FullName; break }
    }
}
if (-not $PYTHONW -or -not (Test-Path $PYTHONW)) {
    Write-Host 'ERROR: Python no encontrado. Instala Python desde python.org' -ForegroundColor Red
    exit 1
}
$PYTHONEXE = $PYTHONW -replace 'pythonw\.exe$','python.exe'
Write-Host ('Python: ' + $PYTHONW) -ForegroundColor Green

Write-Host ''
Write-Host 'Nombre de esta PC (ej: principal, tulipan):' -ForegroundColor Yellow -NoNewline
$PC_NOMBRE = (Read-Host ' ').Trim()
if (-not $PC_NOMBRE) { $PC_NOMBRE = 'pc1' }
Write-Host ("Esta PC se identificara como: " + $PC_NOMBRE) -ForegroundColor Green
Write-Host ''

$DEST = 'C:\liverpool-automation'
New-Item -ItemType Directory -Force -Path $DEST | Out-Null
New-Item -ItemType Directory -Force -Path ($DEST+'\descargas') | Out-Null
New-Item -ItemType Directory -Force -Path ($DEST+'\logs') | Out-Null
Write-Host 'Carpetas OK' -ForegroundColor Green

if ($InstallerDir -ne '' -and (Test-Path (Join-Path $InstallerDir 'credentials.json'))) {
    Copy-Item (Join-Path $InstallerDir 'credentials.json') $DEST -Force
    Write-Host 'credentials.json copiado.' -ForegroundColor Green
} else {
    Write-Host 'ADVERTENCIA: credentials.json no encontrado. Copiarlo manualmente a C:\liverpool-automation\' -ForegroundColor Yellow
}

$B64_MAIN = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'main.py'), [Convert]::FromBase64String($B64_MAIN))
Write-Host 'main.py instalado.' -ForegroundColor Green

$B64_CONFIG = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'config.py'), [Convert]::FromBase64String($B64_CONFIG))
# Patch PC_NOMBRE in config.py
$cfgPath = Join-Path $DEST 'config.py'
$cfgText = [System.IO.File]::ReadAllText($cfgPath, [System.Text.Encoding]::UTF8)
$cfgText = $cfgText -replace 'PC_NOMBRE\s*=\s*"[^"]*"', ('PC_NOMBRE = "' + $PC_NOMBRE + '"')
[System.IO.File]::WriteAllText($cfgPath, $cfgText, [System.Text.Encoding]::UTF8)
Write-Host 'config.py instalado.' -ForegroundColor Green

$B64_DIRECTORIO = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'actualizar_directorio.py'), [Convert]::FromBase64String($B64_DIRECTORIO))
Write-Host 'actualizar_directorio.py instalado.' -ForegroundColor Green

$B64_REPARAR = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'reparar_bot.py'), [Convert]::FromBase64String($B64_REPARAR))
Write-Host 'reparar_bot.py instalado.' -ForegroundColor Green

$B64_PAUSAR = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'pausar_bot.bat'), [Convert]::FromBase64String($B64_PAUSAR))
Write-Host 'pausar_bot.bat instalado.' -ForegroundColor Green

$correr = "@echo off`r`ncd /d C:\liverpool-automation`r`n`"" + $PYTHONEXE + "`" main.py --forzar`r`npause"
[System.IO.File]::WriteAllText((Join-Path $DEST 'correr_ahora.bat'), $correr)
Write-Host 'correr_ahora.bat instalado.' -ForegroundColor Green

$B64_DESINSTALAR = ''
[System.IO.File]::WriteAllBytes((Join-Path $DEST 'desinstalar.bat'), [Convert]::FromBase64String($B64_DESINSTALAR))
Write-Host 'desinstalar.bat instalado.' -ForegroundColor Green

$vbs1 = 'CreateObject("WScript.Shell").Run """' + $PYTHONW + '"" ""C:\liverpool-automation\main.py""", 0, False'
[System.IO.File]::WriteAllText((Join-Path $DEST 'ejecutar.vbs'), $vbs1)
Write-Host 'ejecutar.vbs OK' -ForegroundColor Green

$vbs2 = 'CreateObject("WScript.Shell").Run """' + $PYTHONW + '"" ""C:\liverpool-automation\reparar_bot.py""", 0, False'
[System.IO.File]::WriteAllText((Join-Path $DEST 'ejecutar_reparar.vbs'), $vbs2)
Write-Host 'ejecutar_reparar.vbs OK' -ForegroundColor Green

$correr = "@echo off`r`ncd /d C:\liverpool-automation`r`n`"$PYTHONEXE`" main.py --forzar`r`npause"
[System.IO.File]::WriteAllText((Join-Path $DEST 'correr_ahora.bat'), $correr)
Write-Host 'correr_ahora.bat OK' -ForegroundColor Green

Write-Host ''
Write-Host 'Instalando dependencias...' -ForegroundColor Yellow
& $PYTHONEXE -m pip install --quiet playwright gspread google-auth requests
Write-Host 'Dependencias OK' -ForegroundColor Green

Write-Host 'Instalando Chromium...' -ForegroundColor Yellow
& $PYTHONEXE -m playwright install chromium
Write-Host 'Chromium OK' -ForegroundColor Green

Write-Host 'Creando tareas programadas...' -ForegroundColor Yellow

$xml1 = @'
<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <Triggers>
    <CalendarTrigger>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT11H30M</Duration>
        <StopAtDurationEnd>false</StopAtDurationEnd>
      </Repetition>
      <StartBoundary>2026-01-01T10:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>wscript.exe</Command>
      <Arguments>"C:\liverpool-automation\ejecutar.vbs"</Arguments>
    </Exec>
  </Actions>
  <Settings>
    <StartWhenAvailable>true</StartWhenAvailable>
    <ExecutionTimeLimit>PT14M</ExecutionTimeLimit>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
  </Settings>
</Task>
'@
$xml1 | Out-File "$env:TEMP\task_bot.xml" -Encoding unicode
schtasks /delete /tn 'Liverpool Bot' /f 2>$null | Out-Null
schtasks /create /tn 'Liverpool Bot' /xml "$env:TEMP\task_bot.xml" /f | Out-Null
Write-Host 'Tarea Liverpool Bot creada (10 AM - 9:30 PM cada 15 min).' -ForegroundColor Green

$xml2 = @'
<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <Triggers>
    <CalendarTrigger>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT11H30M</Duration>
        <StopAtDurationEnd>false</StopAtDurationEnd>
      </Repetition>
      <StartBoundary>2026-01-01T10:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>wscript.exe</Command>
      <Arguments>"C:\liverpool-automation\ejecutar_reparar.vbs"</Arguments>
    </Exec>
  </Actions>
  <Settings>
    <StartWhenAvailable>true</StartWhenAvailable>
    <ExecutionTimeLimit>PT14M</ExecutionTimeLimit>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
  </Settings>
</Task>
'@
$xml2 | Out-File "$env:TEMP\task_reparar.xml" -Encoding unicode
schtasks /delete /tn 'Liverpool Bot Reparador' /f 2>$null | Out-Null
schtasks /create /tn 'Liverpool Bot Reparador' /xml "$env:TEMP\task_reparar.xml" /f | Out-Null
Write-Host 'Tarea Liverpool Bot Reparador creada.' -ForegroundColor Green

Write-Host ''
Write-Host '============================================' -ForegroundColor Green
Write-Host '   Instalacion completada exitosamente!     ' -ForegroundColor Green
Write-Host '============================================' -ForegroundColor Green
Write-Host ''
Write-Host 'Archivos: C:\liverpool-automation\' -ForegroundColor White
Write-Host 'Bot corre cada 15 min de 10 AM a 9:30 PM' -ForegroundColor White
Write-Host ''
if (-not (Test-Path (Join-Path $DEST 'credentials.json'))) {
    Write-Host 'RECUERDA: Copia credentials.json a C:\liverpool-automation\' -ForegroundColor Red
}
